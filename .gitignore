# Terraform state and sensitive variable files — never commit these
terraform.tfvars
terraform.tfvars.json
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
