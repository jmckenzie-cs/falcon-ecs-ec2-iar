# terraform.tfvars.example
# Copy this file to terraform.tfvars and fill in your values before running terraform apply.
# Never commit terraform.tfvars to source control.

region = "us-east-1"

falcon_cid           = "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XX"
falcon_client_id     = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
falcon_client_secret = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional overrides (defaults shown):
# falcon_region    = "us-2"
# instance_type    = "t3.medium"
# desired_capacity = 2
# min_size         = 1
# max_size         = 3
